# ── 录像文件（体积大，本地保留，不入库）
data/replays/

# ── 解析结果（可选：如果公开数据则删除此行）
# data/output/

# ── GameID 文件（可选：如不想公开采集来源则取消注释）
# data/gameids/

# ── Per-mode 索引（运行时生成，R2 同步）
data/indexes/*
!data/indexes/.gitkeep

# ── 每日榜单缓存（运行时生成，R2 同步）
data/cache/*
!data/cache/.gitkeep

# ── Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# ── macOS
.DS_Store

# ── 本地文档和 Cookie（绝对不要提交）
README.zh.md
cookies.json
.env
*.env

# ── IDE
.idea/
.vscode/
*.swp
